# Web and API ports exposed by docker compose
WEB_PORT=8081
BACKEND_PORT=18080
MYSQL_PORT=3306
OCR_PORT=8000

# Runtime timezone used by containers and date rendering
TZ=Asia/Shanghai

# Database and auth
DB_PASSWORD=planflow123
JWT_SECRET=change-this-to-a-long-random-secret

# CORS. The default allows local development on any localhost port.
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# AI provider: deepseek | qwen | openai-compatible
AI_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Qwen OpenAI-compatible mode
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

# Custom OpenAI-compatible provider
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Notification channel configuration
EMAIL_NOTIFICATION_ENABLED=false
EMAIL_NOTIFICATION_PROVIDER=smtp
EMAIL_NOTIFICATION_FROM=
SMS_NOTIFICATION_ENABLED=false
SMS_NOTIFICATION_PROVIDER=aliyun
