# PlanFlow AI Frontend Environment Variables

# API Base URL. Web deployment can keep /api; bundled Android builds should use https://your-domain/api.
# VITE_API_BASE=/api

# WebSocket Base URL. Web deployment can omit this; bundled Android builds should use wss://your-domain.
# VITE_WS_BASE=wss://your-domain

# Mock Mode: set to 'true' to use mock data without backend
VITE_USE_MOCK=false
